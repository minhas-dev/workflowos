ENVIRONMENT=production
DATABASE_URL=postgresql://user:password@host:5432/workflowos
SECRET_KEY=replace-with-a-long-random-secret
FRONTEND_URL=https://your-workflowos-frontend.vercel.app
CORS_ORIGINS=https://your-workflowos-frontend.vercel.app
UPLOAD_DIR=uploads

AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://agentrouter.org/
CLAUDE_MODEL=claude-opus-4-6
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

EMAIL_ENABLED=true
SMTP_SERVER=
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=
EMAIL_FROM=

OAUTH_REDIRECT_BASE_URL=https://your-workflowos-backend.onrender.com
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
